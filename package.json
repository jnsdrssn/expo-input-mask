{
  "name": "expo-input-mask",
  "version": "0.3.0",
  "description": "Native input masking for Expo — wraps RedMadRobot's input-mask libraries for iOS and Android",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "files": [
    "build",
    "ios/*.swift",
    "ios/*.podspec",
    "android/build.gradle",
    "android/src/main",
    "expo-module.config.json",
    "CHANGELOG.md"
  ],
  "license": "MIT",
  "homepage": "https://github.com/jnsdrssn/expo-input-mask",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jnsdrssn/expo-input-mask.git"
  },
  "bugs": {
    "url": "https://github.com/jnsdrssn/expo-input-mask/issues"
  },
  "author": "Jonas Derissen",
  "keywords": [
    "react-native",
    "expo",
    "input-mask",
    "text-input",
    "mask",
    "formatting",
    "phone-number",
    "credit-card",
    "date-mask",
    "redmadrobot",
    "ios",
    "android",
    "native-module"
  ],
  "scripts": {
    "build": "expo-module build",
    "clean": "expo-module clean",
    "lint": "expo-module lint",
    "test": "expo-module test",
    "prepare": "expo-module prepare",
    "prepublishOnly": "expo-module prepublishOnly",
    "postpublish": "git tag v$npm_package_version && git push origin v$npm_package_version",
    "expo-module": "expo-module"
  },
  "peerDependencies": {
    "expo": "*",
    "react": "*",
    "react-native": "*"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "expo": "^52.0.0",
    "expo-module-scripts": "^4.0.0",
    "expo-modules-core": "^2.0.0",
    "typescript": "^5.0.0"
  }
}
